{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "paths": {
      "@wato/core": ["./packages/core/src/index.ts"],
      "@wato/kernel": ["./packages/kernel/src/index.ts"],
      "@wato/workflow-types": ["./packages/workflow-types/src/index.ts"],
      "@wato/workflow-engine": ["./packages/workflow-engine/src/index.ts"],
      "@wato/storage-sqlite": ["./packages/storage-sqlite/src/index.ts"],
      "@wato/config": ["./packages/config/src/index.ts"],
      "@wato/logging": ["./packages/logging/src/index.ts"],
      "@wato/account-registry": ["./packages/account-registry/src/index.ts"],
      "@wato/event-bus": ["./packages/event-bus/src/index.ts"],
      "@wato/module-graph": ["./packages/module-graph/src/index.ts"],
      "@wato/api-client": ["./packages/api-client/src/index.ts"],
      "@wato/api-types": ["./packages/api-types/src/index.ts"],
      "@wato/action-data": ["./modules/action-data/src/index.ts"],
      "@wato/action-message": ["./modules/action-message/src/index.ts"],
      "@wato/trigger-message": ["./modules/trigger-message/src/index.ts"],
      "@wato/runtime-whatsapp": ["./modules/runtime-whatsapp/src/index.ts"],
      "@wato/runtime-workflow": ["./modules/runtime-workflow/src/index.ts"],
      "@wato/runtime-webhook": ["./modules/runtime-webhook/src/index.ts"],
      "@wato/runtime-api": ["./modules/runtime-api/src/index.ts"],
      "@wato/runtime-health": ["./modules/runtime-health/src/index.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts",
    "modules/**/*.ts"
  ]
}
