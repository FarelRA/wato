{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "paths": {
      "@wato/sdk": ["./packages/sdk/src/index.ts"],
      "@wato/kernel": ["./packages/kernel/src/index.ts"],
      "@wato/workflow-sdk": ["./packages/workflow-sdk/src/index.ts"],
      "@wato/workflow-engine": ["./packages/workflow-engine/src/index.ts"],
      "@wato/storage-sqlite": ["./packages/storage-sqlite/src/index.ts"],
      "@wato/config": ["./packages/config/src/index.ts"],
      "@wato/logging": ["./packages/logging/src/index.ts"],
      "@wato/account-manager": ["./packages/account-manager/src/index.ts"],
      "@wato/event-bus": ["./packages/event-bus/src/index.ts"],
      "@wato/module-loader": ["./packages/module-loader/src/index.ts"],
      "@wato/ipc": ["./packages/ipc/src/index.ts"],
      "@wato/api-contracts": ["./packages/api-contracts/src/index.ts"],
      "@wato/action-utility": ["./modules/action-utility/src/index.ts"],
      "@wato/webhook-runtime": ["./modules/webhook-runtime/src/index.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts",
    "modules/**/*.ts"
  ]
}
