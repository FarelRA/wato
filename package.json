{
  "name": "wato",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.2.5",
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/*"
  ],
  "scripts": {
    "dev:daemon": "bun run apps/daemon/src/index.ts",
    "dev:cli": "bun run apps/cli/src/index.ts",
    "build:daemon": "bun build apps/daemon/src/index.ts --outfile dist/wato-daemon.js --target bun",
    "build:cli": "bun build apps/cli/src/index.ts --outfile dist/wato.js --target bun",
    "build": "bun run build:daemon && bun run build:cli",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "whatsapp-web.js": "^1.34.6",
    "zod": "^4.3.6"
  }
}
